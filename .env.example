# Copy this file to ".env" and fill in your Alpaca PAPER keys.
# Get them free at https://alpaca.markets -> Paper Trading -> generate keys.
# The real .env is gitignored so your keys never get committed.

ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# Leave this "true". Setting it to false trades REAL money. Don't.
ALPACA_PAPER=true
